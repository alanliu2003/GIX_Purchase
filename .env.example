# --- Local development (Python on host, MySQL on host) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=gix_purchases

# --- Docker Compose (create a separate .env next to docker-compose.yml) ---
# Required for `docker compose up`:
# MYSQL_ROOT_PASSWORD=choose_a_long_random_password
#
# Optional port overrides:
# WEB_PORT=8000
# STREAMLIT_PORT=8501
